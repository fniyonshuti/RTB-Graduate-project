  "author": "Fred Niyonshuti",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "e2b": "^2.34.0",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "google-auth-library": "^10.9.0",
    "mongoose": "^9.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "nodemon": "^3.1.14"
