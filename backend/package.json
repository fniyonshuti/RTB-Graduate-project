{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express API for the RTB ICT TVET Skills Gap Analysis Tool.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "npm run check",
    "dev": "nodemon src/server.js",
