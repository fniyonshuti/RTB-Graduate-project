PORT=5000
HOST=0.0.0.0
NODE_ENV=development
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/rtb_skills_gap?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN_SECONDS=86400

# Password hashing configuration (PBKDF2)
# These settings control the security level of password hashing
# Higher ITERATIONS = more secure but slower. Leave at default for most cases.
PBKDF2_ITERATIONS=120000
PBKDF2_KEY_LENGTH=64
PBKDF2_DIGEST=sha512

DB_CONNECT_TIMEOUT_MS=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=15
TEMPORARY_PASSWORD_EXPIRES_HOURS=72
# Keep false in production. Use true only for local testing without email delivery.
EXPOSE_PASSWORD_RESET_LINK_IN_RESPONSE=true

# First platform admin/superadmin seed.
# Run with: npm run seed:admin
SUPER_ADMIN_NAME=System Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_INSTITUTION=RTB
# Set true only when you intentionally want the seed to reset this admin's password.
SUPER_ADMIN_RESET_PASSWORD=false
# Set true only when the email already exists and you intentionally want to promote it to admin.
SUPER_ADMIN_PROMOTE_EXISTING=false

# Password reset email API.
# Supported providers: resend, brevo, generic
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
# Leave EMAIL_API_URL empty for Resend. It is used only when EMAIL_PROVIDER=generic.
EMAIL_API_URL=
# For Resend production delivery to any recipient, this must be an address from
# a verified Resend domain, for example no-reply@yourdomain.com.
EMAIL_FROM=no-reply@your-verified-domain.com
EMAIL_FROM_NAME=Skills Gap Analysis Tool
# Optional recipient used by npm run test:resend
EMAIL_TEST_TO=

# GitHub repository analysis.
# Public repositories can work without a token, but a token is recommended.
# Private repositories require a token with access to the repository.
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_RAW_BASE_URL=https://raw.githubusercontent.com
GITHUB_API_VERSION=2022-11-28
GITHUB_REQUEST_TIMEOUT_MS=10000
GITHUB_MAX_SAMPLED_FILES=6

# Automated repository execution assessment.
# Keep ENABLE_UNSAFE_LOCAL_REPOSITORY_EXECUTION=false unless running inside a disposable sandbox.
REPOSITORY_ANALYSIS_TIMEOUT_MS=120000
TEMP_REPOSITORY_DIR=tmp/repositories
REPOSITORY_DOCKER_IMAGE=node:20-alpine
ENABLE_UNSAFE_LOCAL_REPOSITORY_EXECUTION=false

# Gemini is required for recommendation generation.
# Get a key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_RECOMMENDATION_MODEL=gemini-2.5-flash
# Optional. Leave empty to use:
# https://generativelanguage.googleapis.com/v1beta/models/<model>:generateContent
GEMINI_RECOMMENDATION_API_URL=
